datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RoleName {
  viewer
  analyst
  admin
}

model User {
  id String @id @default(uuid()) @db.Uuid

  clerkUserId String @unique @map("clerk_user_id") @db.VarChar(255)

  email String @unique @db.VarChar(320)

  fullName String @map("full_name") @db.VarChar(255)

  roleId String @map("role_id") @db.Uuid

  role UserRole @relation(fields: [roleId], references: [id])

  datasets Dataset[]
  reports  Report[]

  isActive Boolean @default(true) @map("is_active")

  lastLoginAt DateTime? @map("last_login_at")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model UserRole {
  id String @id @default(uuid()) @db.Uuid

  roleName RoleName @unique @map("role_name")

  canUpload Boolean @default(false) @map("can_upload")

  canQuery Boolean @default(true) @map("can_query")

  canExport Boolean @default(false) @map("can_export")

  canManageUsers Boolean @default(false) @map("can_manage_users")

  canViewAdminDashboard Boolean @default(false) @map("can_view_admin_dashboard")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  users User[]

  @@map("user_roles")
}

model Dataset {
  id           String   @id @default(uuid()) @db.Uuid

  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id])

  filename     String

  storagePath  String?  @map("storage_path")

  status       String   @default("UPLOADED")

  rowCount     Int?

  redisKey     String?  @map("redis_key")

  errorMessage String?  @map("error_message")

  uploadedAt   DateTime @default(now())

  reports      Report[]

  @@map("datasets")
}

model LLMUsage {
  id            String   @id @default(uuid()) @db.Uuid
  model         String   @db.VarChar(255)
  requestType   String   @map("request_type") @db.VarChar(255)
  inputTokens   Int      @map("input_tokens")
  outputTokens  Int      @map("output_tokens")
  estimatedCost Float    @map("estimated_cost")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("llm_usage")
}

model Report {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  user        User     @relation(fields: [userId], references: [id])
  
  datasetId   String?  @map("dataset_id") @db.Uuid
  dataset     Dataset? @relation(fields: [datasetId], references: [id])

  title       String   @db.VarChar(255)
  content     String   @db.Text
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("reports")
}
