{
    "$schema": "https://turbo.build/schema.json",
    "globalPassThroughEnv": [
        "CLERK_PUBLISHABLE_KEY",
        "CLERK_SECRET_KEY",
        "DATABASE_URL",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "JWT_SECRET",
        "ANTHROPIC_API_KEY",
        "VITE_CLERK_PUBLISHABLE_KEY"
    ],
    "tasks": {
        "dev": {
            "cache": false,
            "persistent": true
        },
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**"
            ]
        }
    }
}